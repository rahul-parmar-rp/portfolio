{
  "private": true,
  "type": "module",
  "scripts": {
    "dev": "next dev",
    "prebuild": "pnpm typecheck && pnpm lint",
    "build": "pnpm prebuild && next build",
    "build:analyze": "ANALYZE=true next build",
    "start": "next start",
    "docs:dev": "pnpm --dir docs/dev-journal start",
    "docs:build": "pnpm --dir docs/dev-journal build",
    "docs:serve": "pnpm --dir docs/dev-journal serve",
    "docs:typecheck": "pnpm --dir docs/dev-journal typecheck",
    "docs:sync:app-ideas": "rsync -a workspace/projects/app-ideas/ docs/dev-journal/docs/app-ideas/",
    "ports:kill": "sh -c 'ports=$(lsof -tiTCP:2998,4005,3000,3001,3002,3003,3004,3005,6006,6007,6008,8080,8081,4200,5600,5432 -sTCP:LISTEN); if [ -n \"$ports\" ]; then echo \"$ports\" | xargs kill -9; fi'",
    "submodule:status": "git submodule status",
    "submodule:init": "git submodule update --init --recursive",
    "git:sync-submodules": "git submodule update --init --recursive --remote",
    "submodule:sync": "git submodule sync --recursive",
    "submodule:example:status": "git -C workspace/git-submodules-example-repo status --short --branch",
    "submodule:example:commit": "sh -c 'msg=${MSG:-\"Update submodule\"}; git -C workspace/git-submodules-example-repo add -A && git -C workspace/git-submodules-example-repo commit -m \"$msg\"'",
    "submodule:example:push": "git -C workspace/git-submodules-example-repo push",
    "submodule:parent:stage": "git add .gitmodules workspace/git-submodules-example-repo",
    "submodule:parent:commit": "sh -c 'msg=${MSG:-\"Update submodule pointer\"}; git commit -m \"$msg\"'",
    "submodule:parent:push": "git push",
    "lint": "eslint .",
    "typecheck": "tsc --noEmit",
    "prettier-check": "prettier --check '**/*.{js,ts,jsx,tsx,css,json,md,yml,yaml}'",
    "prettier-write": "prettier --write '**/*.{js,ts,jsx,tsx,css,json,md,yml,yaml}'",
    "twitter:post-time": "node tools/twitter-poster/scripts/post-single.js",
    "twitter:post-csv": "node tools/twitter-poster/scripts/post.js",
    "tweet-date": "node tools/twitter-poster/scripts/tweet-date.js",
    "setup:repos:all": "bash setup.sh",
    "tree:sample": "pnpm ls minimatch >> sample.md"
  },
  "dependencies": {
    "@tailwindcss/postcss": "4.0.0-alpha.13",
    "@types/node": "20.11.17",
    "@types/react": "18.2.55",
    "@types/react-dom": "18.2.19",
    "@vercel/analytics": "^1.1.3",
    "@vercel/speed-insights": "^1.0.9",
    "csv-parser": "^3.2.0",
    "dotenv": "^16.6.1",
    "geist": "1.2.2",
    "next": "^16.0.10",
    "next-mdx-remote": "^4.4.1",
    "postcss": "^8.4.35",
    "react": "^19.2.1",
    "react-dom": "^19.2.1",
    "sugar-high": "^0.6.0",
    "tailwindcss": "4.0.0-alpha.13",
    "twitter-api-v2": "^1.29.0",
    "typescript": "^5"
  },
  "devDependencies": {
    "@eslint/eslintrc": "^3.3.3",
    "@typescript-eslint/eslint-plugin": "^8.54.0",
    "@typescript-eslint/parser": "^8.54.0",
    "eslint": "^9",
    "eslint-config-next": "^16.0.10",
    "prettier": "^3.2.5"
  },
  "packageManager": "pnpm@11.5.0+sha512.dbfcc4f81cf48597afd4bc391ffdf12c11f1a9fb83a395bfa6b0a2d9cc2fd8ffebafdb1ccbd529632153f793904c2615b7f09fe1a345473fd1c35845172a8eb1"
}
